From 3a7d6b9b3a6b2b7e5d3f7ac9b7a36d26ab9f7d6a Mon Sep 17 00:00:00 2001
From: Tuxbox OS Builder <noreply@example.com>
Date: Tue, 17 Dec 2024 00:00:00 +0000
Subject: [PATCH] Fix format-security warnings in cdparanoia

Use explicit format strings for fprintf to satisfy -Wformat-security.
---
 main.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/main.c b/main.c
index 2d5ad14..1c4fdf2 100644
--- a/main.c
+++ b/main.c
@@ -591,7 +591,7 @@ int callback(long int inpos, long int outpos){
 
       if(!logfile){
         fprintf(stderr,"Error opening log file\n");
-        fprintf(stderr,buffer);
+        fprintf(stderr,"%s",buffer);
         exit(1);
       }else
         log_thread=1;
@@ -594,7 +594,7 @@ int callback(long int inpos, long int outpos){
     }
   }else
     if(logfile){
-      fprintf(logfile,buffer+1);
+      fprintf(logfile,"%s",buffer+1);
     }
 
   return(0);
