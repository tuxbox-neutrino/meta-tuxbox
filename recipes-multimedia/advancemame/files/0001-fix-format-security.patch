From 4f9b6f6e6a2e5c7b8f4e3c0a6e9c7f1f2c0b1234 Mon Sep 17 00:00:00 2001
From: Tuxbox Neutrino Team <team@tuxbox-neutrino.org>
Date: Tue, 20 Jan 2026 12:10:00 +0100
Subject: [PATCH] menu: fix format-security warning

Use an explicit format string to avoid -Werror=format-security.
---
 advance/menu/emulator.cc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/advance/menu/emulator.cc b/advance/menu/emulator.cc
index 1234567..89abcde 100644
--- a/advance/menu/emulator.cc
+++ b/advance/menu/emulator.cc
@@ -2206,7 +2206,7 @@ bool advmess::compile(const game& g, const string& cpath, bool ignore_error)
 						}
 					}
 					error += "\n";
-					target_err(error.c_str());
+					target_err("%s", error.c_str());
 				}
 
 				for (int i = 0; i < argc; ++i)
