From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Tuxbox Build <build@tuxbox.local>
Date: Sun, 3 May 2026 00:00:00 +0200
Subject: [PATCH] configure: use pkg-config for libgcrypt and gpg-error

OE-Core does not support using the target libgcrypt-config wrapper from
cross builds. Current upstream libaacs can use gpgrt-config, but the
Kirkstone based build environment does not expose a working gpgrt-config
for this recipe, so the configure check falls back to the blocked
libgcrypt-config path.

Use pkg-config directly for libgcrypt and gpg-error detection.

Upstream-Status: Inappropriate [oe-specific]
---
 configure.ac | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/configure.ac b/configure.ac
index 52b0a67..0d3dcb4 100644
--- a/configure.ac
+++ b/configure.ac
@@ -100,10 +100,10 @@ AC_SYS_LARGEFILE
 dnl required libraries
 
 dnl gcrypt check
-AM_PATH_LIBGCRYPT([1.6.0], [have_gcrypt=yes])
+PKG_CHECK_MODULES([LIBGCRYPT], [libgcrypt >= 1.6.0], [have_gcrypt=yes], [have_gcrypt=no])
 AS_IF([test "x$have_gcrypt" != xyes],[
     dnl older gcrypt requires pthread
-    AM_PATH_LIBGCRYPT([1.1.94],,
+    PKG_CHECK_MODULES([LIBGCRYPT], [libgcrypt >= 1.1.94],,
                       AC_MSG_ERROR([libgcrypt not found on system]))
     dnl pthread check (not on win32)
     AS_IF([test "${SYS}" != "mingw32"], [
@@ -116,8 +116,8 @@ AS_IF([test "x$have_gcrypt" != xyes],[
 
 dnl use re-entrant version of gcrypt_error() from gpg-error
 AC_FUNC_STRERROR_R
-AM_PATH_GPG_ERROR([0.5],
-                  AC_DEFINE(HAVE_LIBGPG_ERROR, 1, [Define to 1 if you have the gpg-error library]))
+PKG_CHECK_MODULES([GPG_ERROR], [gpg-error >= 0.5],
+                  [AC_DEFINE(HAVE_LIBGPG_ERROR, 1, [Define to 1 if you have the gpg-error library])])
 
 dnl aacs_info can be used with unmounted discs if libudfread is used
 PKG_CHECK_MODULES([LIBUDFREAD], [libudfread >= 1.1.0],
-- 
2.39.5

