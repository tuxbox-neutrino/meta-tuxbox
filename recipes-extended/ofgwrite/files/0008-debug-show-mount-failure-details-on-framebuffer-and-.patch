From b62f2507924ddba50a0dda048427b2917e24c4c8 Mon Sep 17 00:00:00 2001
From: Thilo Graf <dbt@novatux.de>
Date: Sun, 5 Apr 2026 00:33:48 +0200
Subject: [PATCH] debug: show mount failure details on framebuffer and kmsg

Write per-mount errno to kernel ring buffer via /oldroot/dev/kmsg
(survives reboot, readable via dmesg). Show last error on
framebuffer so the user sees which mount operation failed.
---
 ofgwrite.c | 52 +++++++++++++++++++++++++++++-----------------------
 1 file changed, 29 insertions(+), 23 deletions(-)

diff --git a/ofgwrite.c b/ofgwrite.c
index c1d1846..900989c 100644
--- a/ofgwrite.c
+++ b/ofgwrite.c
@@ -1386,6 +1386,7 @@ int umount_rootfs(int steps)
 	ret = chdir("/");
 
 	// move/create mounts in new root
+	char errbuf[256] = {0};
 	ret = 0;
 	if (init_sys == INIT_SYSTEMD)
 	{
@@ -1394,19 +1395,38 @@ int umount_rootfs(int steps)
 		// Mount fresh virtual filesystems instead and bind-mount var/volatile
 		// (which may contain the image files under /tmp).
 		int r;
+		// Log to kernel ring buffer (survives reboot, readable via dmesg)
+		FILE *kmsg = fopen("/oldroot/dev/kmsg", "w");
 		my_printf("systemd: mounting fresh dev/proc/sys, bind var/volatile\n");
 		r = mount("devtmpfs", "dev/", "devtmpfs", 0, NULL);
-		if (r) my_printf("  mount devtmpfs on dev/: %s\n", strerror(errno));
+		if (r) {
+			snprintf(errbuf, sizeof(errbuf), "devtmpfs->dev/: %s", strerror(errno));
+			my_printf("  FAIL %s\n", errbuf);
+			if (kmsg) fprintf(kmsg, "<3>ofgwrite: FAIL %s\n", errbuf);
+		} else { my_printf("  OK devtmpfs\n"); }
 		ret += (r != 0);
 		r = mount("proc", "proc/", "proc", 0, NULL);
-		if (r) my_printf("  mount proc on proc/: %s\n", strerror(errno));
+		if (r) {
+			snprintf(errbuf, sizeof(errbuf), "proc->proc/: %s", strerror(errno));
+			my_printf("  FAIL %s\n", errbuf);
+			if (kmsg) fprintf(kmsg, "<3>ofgwrite: FAIL %s\n", errbuf);
+		} else { my_printf("  OK proc\n"); }
 		ret += (r != 0);
 		r = mount("sysfs", "sys/", "sysfs", 0, NULL);
-		if (r) my_printf("  mount sysfs on sys/: %s\n", strerror(errno));
+		if (r) {
+			snprintf(errbuf, sizeof(errbuf), "sysfs->sys/: %s", strerror(errno));
+			my_printf("  FAIL %s\n", errbuf);
+			if (kmsg) fprintf(kmsg, "<3>ofgwrite: FAIL %s\n", errbuf);
+		} else { my_printf("  OK sysfs\n"); }
 		ret += (r != 0);
 		r = mount("/oldroot/var/volatile", "var/volatile/", NULL, MS_BIND, NULL);
-		if (r) my_printf("  bind mount var/volatile: %s\n", strerror(errno));
+		if (r) {
+			snprintf(errbuf, sizeof(errbuf), "bind var/volatile: %s", strerror(errno));
+			my_printf("  FAIL %s\n", errbuf);
+			if (kmsg) fprintf(kmsg, "<3>ofgwrite: FAIL %s\n", errbuf);
+		} else { my_printf("  OK var/volatile\n"); }
 		ret += (r != 0);
+		if (kmsg) fclose(kmsg);
 	}
 	else
 	{
@@ -1427,25 +1447,11 @@ int umount_rootfs(int steps)
 	{
 		my_printf("Error move mounts to newroot (ret=%d)\n", ret);
 		set_error_text1("Error move mounts to newroot. Abort flashing!");
-		set_error_text2("Rebooting in 30 seconds!");
-		// Save debug info to old root (still mounted at /oldroot/)
-		{
-			FILE *dbg = fopen("/oldroot/root/ofgwrite_debug.log", "w");
-			if (dbg)
-			{
-				fprintf(dbg, "mount setup failed, ret=%d, init_sys=%d\n", ret, init_sys);
-				fprintf(dbg, "cwd after chdir: ");
-				char cwd[256] = {0};
-				if (getcwd(cwd, sizeof(cwd)))
-					fprintf(dbg, "%s\n", cwd);
-				else
-					fprintf(dbg, "(error: %s)\n", strerror(errno));
-				fclose(dbg);
-			}
-			system("cat /proc/mounts > /oldroot/root/ofgwrite_mounts.log 2>/dev/null");
-			system("dmesg | tail -100 > /oldroot/root/ofgwrite_dmesg.log 2>/dev/null");
-			my_printf("Debug logs saved to /oldroot/root/ofgwrite_*.log\n");
-		}
+		// Show which mount failed on framebuffer
+		if (errbuf[0])
+			set_error_text2(errbuf);
+		else
+			set_error_text2("Rebooting in 30 seconds!");
 		sleep(30);
 		reboot(LINUX_REBOOT_CMD_RESTART);
 		return 0;
