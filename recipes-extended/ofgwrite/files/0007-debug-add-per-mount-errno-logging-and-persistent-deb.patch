From 0ace466839657e1a8a720c062166da4d9da74c20 Mon Sep 17 00:00:00 2001
From: Thilo Graf <dbt@novatux.de>
Date: Sun, 5 Apr 2026 00:28:02 +0200
Subject: [PATCH] debug: add per-mount errno logging and persistent debug log

Log individual mount failures with strerror(errno) to identify
which exact mount operation fails. On error, save debug info,
/proc/mounts snapshot and dmesg tail to /oldroot/root/ which
survives reboot (old rootfs still mounted at error time).
---
 ofgwrite.c | 44 ++++++++++++++++++++++++++++++++++++++------
 1 file changed, 38 insertions(+), 6 deletions(-)

diff --git a/ofgwrite.c b/ofgwrite.c
index 74dffd8..c1d1846 100644
--- a/ofgwrite.c
+++ b/ofgwrite.c
@@ -1393,11 +1393,20 @@ int umount_rootfs(int steps)
 		// cannot be moved across peer groups, and private->slave is a no-op).
 		// Mount fresh virtual filesystems instead and bind-mount var/volatile
 		// (which may contain the image files under /tmp).
+		int r;
 		my_printf("systemd: mounting fresh dev/proc/sys, bind var/volatile\n");
-		ret =  mount("devtmpfs", "dev/", "devtmpfs", 0, NULL);
-		ret += mount("proc", "proc/", "proc", 0, NULL);
-		ret += mount("sysfs", "sys/", "sysfs", 0, NULL);
-		ret += mount("/oldroot/var/volatile", "var/volatile/", NULL, MS_BIND, NULL);
+		r = mount("devtmpfs", "dev/", "devtmpfs", 0, NULL);
+		if (r) my_printf("  mount devtmpfs on dev/: %s\n", strerror(errno));
+		ret += (r != 0);
+		r = mount("proc", "proc/", "proc", 0, NULL);
+		if (r) my_printf("  mount proc on proc/: %s\n", strerror(errno));
+		ret += (r != 0);
+		r = mount("sysfs", "sys/", "sysfs", 0, NULL);
+		if (r) my_printf("  mount sysfs on sys/: %s\n", strerror(errno));
+		ret += (r != 0);
+		r = mount("/oldroot/var/volatile", "var/volatile/", NULL, MS_BIND, NULL);
+		if (r) my_printf("  bind mount var/volatile: %s\n", strerror(errno));
+		ret += (r != 0);
 	}
 	else
 	{
@@ -1408,12 +1417,35 @@ int umount_rootfs(int steps)
 		ret += mount("/oldroot/var/volatile", "var/volatile/", NULL, MS_MOVE, NULL);
 	}
 	// create link for tmp
-	ret += symlink("/var/volatile/tmp", "/tmp");
+	{
+		int r = symlink("/var/volatile/tmp", "/tmp");
+		if (r) my_printf("  symlink /tmp -> /var/volatile/tmp: %s\n", strerror(errno));
+		ret += (r != 0);
+	}
+	my_printf("mount setup result: ret=%d\n", ret);
 	if (ret != 0)
 	{
-		my_printf("Error move mounts to newroot\n");
+		my_printf("Error move mounts to newroot (ret=%d)\n", ret);
 		set_error_text1("Error move mounts to newroot. Abort flashing!");
 		set_error_text2("Rebooting in 30 seconds!");
+		// Save debug info to old root (still mounted at /oldroot/)
+		{
+			FILE *dbg = fopen("/oldroot/root/ofgwrite_debug.log", "w");
+			if (dbg)
+			{
+				fprintf(dbg, "mount setup failed, ret=%d, init_sys=%d\n", ret, init_sys);
+				fprintf(dbg, "cwd after chdir: ");
+				char cwd[256] = {0};
+				if (getcwd(cwd, sizeof(cwd)))
+					fprintf(dbg, "%s\n", cwd);
+				else
+					fprintf(dbg, "(error: %s)\n", strerror(errno));
+				fclose(dbg);
+			}
+			system("cat /proc/mounts > /oldroot/root/ofgwrite_mounts.log 2>/dev/null");
+			system("dmesg | tail -100 > /oldroot/root/ofgwrite_dmesg.log 2>/dev/null");
+			my_printf("Debug logs saved to /oldroot/root/ofgwrite_*.log\n");
+		}
 		sleep(30);
 		reboot(LINUX_REBOOT_CMD_RESTART);
 		return 0;
